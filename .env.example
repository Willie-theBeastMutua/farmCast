# Weather API — required when integrating a real weather provider
WEATHER_API_KEY=your_openweathermap_api_key

# Weather API base URL (optional, defaults to OpenWeatherMap v2.5)
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# OpenAI API key (optional — enables AI-powered image analysis)
OPENAI_API_KEY=your_openai_api_key

# Application URL (used for absolute links and metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API base URL for client-side HTTP calls (leave empty to use relative paths)
NEXT_PUBLIC_API_BASE_URL=
